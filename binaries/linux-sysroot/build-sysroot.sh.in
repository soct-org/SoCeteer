#!/bin/sh
# Generated by linux-sysroot/CMakeLists.txt. Builds the riscv64-linux-musl sysroot:
#  1. the kernel tree's sanitized UAPI headers (headers_install),
#  2. musl (static), compiled with the discovered LLVM; the repo toolchain's libgcc
#     supplies the compiler runtime helpers (soft fp128 etc.) as musl's LIBCC,
#  3. link collateral clang's driver expects from a GNU-shaped sysroot: libgcc(_eh).a
#     and empty crtbegin/crtend objects (musl uses init_array; the legacy ctors
#     machinery those objects implement is unused, but the driver still names them).
set -e
@HOSTBIN_LINE@

echo "[sysroot] installing kernel UAPI headers..."
"@BOOT_MAKE@" -C "@LINUX_DIR@" ARCH=riscv O="@HDR_BUILD@" INSTALL_HDR_PATH="@SYSROOT@/usr" headers_install

echo "[sysroot] building musl..."
mkdir -p "@MUSL_BUILD@"
cd "@MUSL_BUILD@"
CC="@CLANG@ --target=riscv64-unknown-linux-musl -march=@MARCH@ -mabi=lp64d --ld-path=@LLD@" \
AR="@LLVM_AR@" RANLIB="@LLVM_RANLIB@" \
LIBCC="@LIBGCC@" \
"@MUSL_SRC@/configure" --target=riscv64-unknown-linux-musl --prefix=/usr --syslibdir=/usr/lib --disable-shared > configure.log
"@BOOT_MAKE@" -j@NCPU@ > build.log
"@BOOT_MAKE@" DESTDIR="@SYSROOT@" install > install.log

echo "[sysroot] adding link collateral..."
cp "@LIBGCC@" "@SYSROOT@/usr/lib/libgcc.a"
cp "@LIBGCC@" "@SYSROOT@/usr/lib/libgcc_eh.a"
for crt in crtbegin.o crtend.o crtbeginT.o crtendT.o crtbeginS.o crtendS.o; do
    "@CLANG@" --target=riscv64-unknown-linux-musl -march=@MARCH@ -mabi=lp64d \
        -c -x c /dev/null -o "@SYSROOT@/usr/lib/$crt"
done

touch "@STAMP@"
echo "[sysroot] done: @SYSROOT@"
