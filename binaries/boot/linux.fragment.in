# Kernel config fragment merged onto the riscv defconfig (boot/CMakeLists.txt).
#
# The console lives on the design's AXI UART Lite; the SoC's device tree carries no
# /chosen node, so the command line is baked in (and forced). HZ is pinned so the
# timeconst generation is deterministic across hosts. The rootfs is an initramfs
# embedded into the Image - the SD controller has no mainline driver, so there is
# no storage for Linux to mount.
# AppArmor is useless on this SoC and its capability_names.h generation needs GNU
# sed (\L), which BSD/macOS sed lacks - the only known GNU-sed site in the build.
# CONFIG_SECURITY_APPARMOR is not set
CONFIG_SERIAL_UARTLITE=y
CONFIG_SERIAL_UARTLITE_CONSOLE=y
CONFIG_CMDLINE="@SOCT_LINUX_CMDLINE@"
CONFIG_CMDLINE_FORCE=y
CONFIG_HZ_250=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE="@SOCT_BOOT_INITRAMFS_DESC@"
